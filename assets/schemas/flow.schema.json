{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://office-skills.local/schemas/flow.schema.json",
  "title": "Office Skills — Flow Schema",
  "description": "Define um fluxo executavel que encadeia Skills via mapeamento input/output.",
  "type": "object",
  "required": ["name", "description", "version", "inputs", "steps", "outputs"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "required", "description"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "required": { "type": "boolean" },
          "description": { "type": "string" }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "skill"],
        "properties": {
          "id": { "type": "string" },
          "skill": { "type": "string" },
          "input_from": {
            "type": "object",
            "description": "Mapa {campo_destino: fonte.campo}"
          },
          "input": {
            "type": "object",
            "description": "Valores literais ou referencias"
          },
          "output": {
            "type": "string",
            "description": "Nome do artefato intermediario a ser armazenado"
          },
          "when": {
            "type": "string",
            "description": "Expressao condicional para executar o step"
          }
        }
      }
    },
    "error_policy": {
      "type": "string",
      "enum": ["abortar", "continuar", "dry_run"],
      "default": "abortar"
    }
  }
}